{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyra.local/schemas/task-recommendation.schema.json",
  "title": "Task Recommendation",
  "type": "object",
  "required": ["schemaType", "id", "sourceThread", "targetAgents", "createdAt", "task", "priority", "safety"],
  "properties": {
    "schemaType": { "const": "task_recommendation" },
    "id": { "type": "string", "minLength": 3 },
    "sourceThread": { "$ref": "./shared-definitions.schema.json#/$defs/sourceThread" },
    "targetAgents": { "$ref": "./shared-definitions.schema.json#/$defs/targetAgents" },
    "createdAt": { "type": "string" },
    "task": { "type": "string", "minLength": 1 },
    "priority": { "enum": ["low", "medium", "high"] },
    "rationale": { "type": "string" },
    "safety": { "$ref": "./shared-definitions.schema.json#/$defs/safety" }
  },
  "additionalProperties": true
}
